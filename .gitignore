# ==========================================
# Graph-Based Data Modeling System .gitignore
# ==========================================

# 1. Environment Variables & Secrets
# Do not commit API keys or environment-specific configs
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.local

# 2. Node.js & Frontend (React/Vite)
frontend/node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 3. Python & Backend (FastAPI)
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/venv/
backend/env/
venv/
env/
.venv/

# 4. Data, Databases, and Generated Models
# These files are generated by scripts (load_dataset_to_sqlite.py and graph_builder.py)
# and can be rebuilt locally, so they shouldn't clutter the git history.
*.db
*.sqlite
*.sqlite3
graph_data.db
graph_model.graphml

# You may choose to uncomment the line below to ignore the raw dataset folder if it's large:
dataset/

# 5. Logs & AI Documentation
# Ignore diagnostic logs generated during AI coding sessions
AI_Logs/
Conversation_Log.md
*.log

# 6. Operating System & IDE Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
